{
  "id": "meeting-transcribe-cloud",
  "name": "Meeting Transcribe Cloud",
  "version": "0.1.0",
  "description": "OpenClaw plugin config surface for meeting audio transcription providers.",
  "entry": "index.js",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "$defs": {
      "secretRef": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "provider", "id"],
        "properties": {
          "source": {
            "type": "string",
            "enum": ["env", "file", "exec"]
          },
          "provider": {
            "type": "string"
          },
          "id": {
            "type": "string"
          }
        }
      }
    },
    "required": ["defaultProvider", "providers"],
    "properties": {
      "defaultProvider": {
        "type": "string",
        "enum": ["auto", "groq", "openai", "local", "mock"]
      },
      "fallback": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "order": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["groq", "openai", "local", "mock"]
            }
          },
          "diarizeOrder": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["openai", "local"]
            }
          }
        }
      },
      "costStrategy": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "default": {
            "type": "string"
          },
          "diarizePolicy": {
            "type": "string"
          }
        }
      },
      "providers": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "groq": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "model": {
                "type": "string",
                "default": "whisper-large-v3-turbo"
              },
              "apiKey": {
                "oneOf": [
                  {"type": "string", "minLength": 1},
                  {"$ref": "#/$defs/secretRef"}
                ]
              }
            }
          },
          "openai": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "model": {
                "type": "string",
                "default": "gpt-4o-mini-transcribe"
              },
              "diarizeModel": {
                "type": "string",
                "default": "gpt-4o-transcribe-diarize"
              },
              "apiKey": {
                "oneOf": [
                  {"type": "string", "minLength": 1},
                  {"$ref": "#/$defs/secretRef"}
                ]
              }
            }
          },
          "local": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "command": {
                "oneOf": [
                  {"type": "string", "minLength": 1},
                  {"$ref": "#/$defs/secretRef"}
                ]
              }
            }
          },
          "mock": {
            "type": "object",
            "additionalProperties": false,
            "properties": {}
          }
        }
      }
    }
  }
}
